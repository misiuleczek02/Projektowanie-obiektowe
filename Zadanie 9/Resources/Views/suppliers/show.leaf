                        <td>#(product.categoryName)</td>
                    </tr>
                #endfor
            </tbody>
        </table>
    #endif
    <div class="actions" style="margin-top:1rem">
        <a class="btn" href="/suppliers/#(supplier.id)/edit">Edytuj</a>
        <a class="btn ghost" href="/suppliers">← Powrót</a>
    </div>
