        <p class="empty">Ten dostawca nie ma przypisanych produktów.</p>
    #else:
        <table>
            <thead><tr><th>Nazwa</th><th>Cena</th><th>Kategoria</th></tr></thead>
            <tbody>
                #for(product in products):
                    <tr>
                        <td><a href="/products/#(product.id)">#(product.name)</a></td>
